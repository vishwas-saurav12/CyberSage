{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CyberSage Chat Response",
  "type": "object",
  "required": [
    "attack_id",
    "attack_name",
    "summary",
    "attack_vector",
    "impact",
    "prevention",
    "severity",
    "confidence"
  ],
  "properties": {
    "attack_id": {
      "type": "string",
      "description": "Unique identifier of the cyber attack"
    },
    "attack_name": {
      "type": "string",
      "description": "Human-readable name of the attack"
    },
    "summary": {
      "type": "string",
      "description": "High-level explanation of the attack"
    },
    "attack_vector": {
      "type": "string",
      "description": "Primary technique or vulnerability used"
    },
    "impact": {
      "type": "string",
      "description": "Business, technical, and operational impact"
    },
    "prevention": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Actionable prevention steps"
    },
    "severity": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"],
      "description": "Severity classification of the attack"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score based on retrieved knowledge"
    }
  },
  "additionalProperties": false
}
